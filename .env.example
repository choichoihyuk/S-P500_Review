# Telegram Bot (필수)
# @BotFather에서 /newbot 으로 발급받은 토큰
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 전송 대상 채널 ID
# - 공개 채널:    @channelname
# - 비공개 채널:   -100으로 시작하는 숫자 ID
# - 개인 DM:      양의 정수 user_id (봇에 /start 전송한 후 getUpdates로 확인)
TELEGRAM_CHANNEL_ID=@your_channel_or_-1001234567890

# (선택) 외부 뉴스 API — 현재는 yfinance 뉴스만 사용하므로 비워둬도 됨
# NewsAPI: https://newsapi.org
NEWS_API_KEY=

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
